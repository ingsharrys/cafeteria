{
    "name": "sharrys/cafeteria",
    "description": "Sistema de gestión para cafetería / POS (pedidos, mesas, meseros, caja, domicilios y WhatsApp).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "phpoffice/phpspreadsheet": "^1.29",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "app/controllers/",
            "App\\Models\\": "app/models/",
            "App\\Middleware\\": "app/middleware/",
            "App\\Services\\": "app/Services/",
            "App\\": "app/",
            "Core\\": "core/",
            "Config\\": "config/"
        }
    },
    "scripts": {
        "lint": "php-cs-fixer fix --dry-run --diff",
        "fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse app core config --level=3"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
