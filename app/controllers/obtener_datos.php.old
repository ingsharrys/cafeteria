<?php
/**
 * obtener_datos.php - CORREGIDO
 * Ubicación: /app/controllers/obtener_datos.php
 * 
 * IMPORTANTE: Este archivo NO debe mostrar ningún error PHP
 */

// ✅ DESACTIVAR errores HTML
error_reporting(0);
ini_set('display_errors', 0);
ini_set('display_startup_errors', 0);

// ✅ Header JSON PRIMERO
header('Content-Type: application/json; charset=utf-8');

// ✅ Capturar TODOS los errores
try {
    // Cargar database
    $dbPath = __DIR__ . '/../../config/database.php';
    
    if (!file_exists($dbPath)) {
        throw new Exception('database.php no encontrado');
    }
    
    require_once $dbPath;
    
    // Verificar clase Database
    if (!class_exists('Database')) {
        throw new Exception('Clase Database no existe');
    }
    
    // Conectar
    $db = new Database();
    $conn = $db->getConnection();
    
    if (!$conn instanceof PDO) {
        throw new Exception('Conexión PDO falló');
    }
    
    // ============================================
    // PEDIDO ESPECÍFICO
    // ============================================
    if (isset($_GET['numero_pedido'])) {
        $numeroPedido = (int)$_GET['numero_pedido'];
        
        if ($numeroPedido <= 0) {
            echo json_encode([
                'success' => false,
                'message' => 'Número de pedido inválido'
            ]);
            exit;
        }
        
        $pedido = obtenerDatosPedido($conn, $numeroPedido);
        
        if (!$pedido) {
            echo json_encode([
                'success' => false,
                'message' => 'Pedido no encontrado'
            ]);
            exit;
        }
        
        $pedido['mesas_libres'] = obtenerMesasLibres($conn);
        $pedido['success'] = true;
        
        echo json_encode($pedido);
        exit;
    }
    
    // ============================================
    // TODAS LAS MESAS
    // ============================================
    $query = "
        SELECT
            m.numero_mesa,
            COALESCE(m.estado, '') AS estado,
            m.id_pedido,
            m.fecha,
            CASE
                WHEN EXISTS (SELECT 1 FROM caja WHERE id_pedidoc = m.id_pedido)
                THEN 1 ELSE 0
            END AS pagado
        FROM mesas m
        WHERE (m.id_pedido IS NULL)
           OR (DATE(m.fecha) = CURDATE())
        ORDER BY m.numero_mesa
    ";
    
    $stmt = $conn->prepare($query);
    $stmt->execute();
    $mesas = $stmt->fetchAll(PDO::FETCH_ASSOC);
    
    // Convertir tipos
    foreach ($mesas as &$mesa) {
        $mesa['pagado'] = (int)$mesa['pagado'];
        $mesa['numero_mesa'] = (int)$mesa['numero_mesa'];
        $mesa['id_pedido'] = $mesa['id_pedido'] ? (int)$mesa['id_pedido'] : null;
    }
    unset($mesa);
    
    $mesasLibres = obtenerMesasLibres($conn);
    
    // ✅ Respuesta exitosa
    echo json_encode([
        'success' => true,
        'mesas' => $mesas,
        'mesas_libres' => $mesasLibres
    ]);
    
} catch (PDOException $e) {
    // Error de base de datos
    echo json_encode([
        'success' => false,
        'message' => 'Error de base de datos',
        'error' => $e->getMessage()
    ]);
    
} catch (Exception $e) {
    // Otros errores
    echo json_encode([
        'success' => false,
        'message' => 'Error del servidor',
        'error' => $e->getMessage()
    ]);
}

exit;

// ============================================
// FUNCIONES AUXILIARES
// ============================================

function pedidoEstaPagado($conn, $numeroPedido) {
    try {
        $query = "SELECT COUNT(*) as count FROM caja WHERE id_pedidoc = ?";
        $stmt = $conn->prepare($query);
        $stmt->bindValue(1, $numeroPedido, PDO::PARAM_STR);
        $stmt->execute();
        $result = $stmt->fetch(PDO::FETCH_ASSOC);
        return $result['count'] > 0;
    } catch (Exception $e) {
        return false;
    }
}

function obtenerProductosPorNumeroPedido($conn, $numeroPedido) {
    try {
        $query = "
            SELECT 
                p.cantidad, 
                p.detalle, 
                p.tipo_producto, 
                p.mesa, 
                pr.precio, 
                prod.nombre 
            FROM pedidos p
            JOIN precios pr ON p.id_pro = pr.idproduc AND p.tipo_producto = pr.tipo_prod
            JOIN productos prod ON p.id_pro = prod.id_pro
            WHERE p.numero_pedido = ?
        ";
        
        $stmt = $conn->prepare($query);
        $stmt->bindParam(1, $numeroPedido, PDO::PARAM_INT);
        $stmt->execute();
        return $stmt->fetchAll(PDO::FETCH_ASSOC);
    } catch (Exception $e) {
        return [];
    }
}

function obtenerNombreMesero($conn, $idMesero) {
    if (!$idMesero) return 'No asignado';
    
    try {
        $query = "SELECT nombre_mese FROM meseros WHERE id_mese = ?";
        $stmt = $conn->prepare($query);
        $stmt->bindParam(1, $idMesero, PDO::PARAM_INT);
        $stmt->execute();
        $mesero = $stmt->fetch(PDO::FETCH_ASSOC);
        
        return $mesero ? $mesero['nombre_mese'] : 'No asignado';
    } catch (Exception $e) {
        return 'No asignado';
    }
}

function obtenerComentarios($conn, $numeroPedido) {
    try {
        $query = "SELECT comentario FROM comentarios WHERE id_pedido = ?";
        $stmt = $conn->prepare($query);
        $stmt->bindParam(1, $numeroPedido, PDO::PARAM_INT);
        $stmt->execute();
        return $stmt->fetchAll(PDO::FETCH_COLUMN);
    } catch (Exception $e) {
        return [];
    }
}

function obtenerDatosPedido($conn, $numeroPedido) {
    try {
        $query = "
            SELECT 
                p.*, 
                m.numero_mesa 
            FROM pedidos p 
            LEFT JOIN mesas m ON p.mesa = m.idm 
            WHERE p.numero_pedido = ?
        ";
        
        $stmt = $conn->prepare($query);
        $stmt->bindParam(1, $numeroPedido, PDO::PARAM_INT);
        $stmt->execute();
        $pedido = $stmt->fetch(PDO::FETCH_ASSOC);
        
        if ($pedido) {
            $pedido['productos'] = obtenerProductosPorNumeroPedido($conn, $numeroPedido);
            $pedido['pagado'] = pedidoEstaPagado($conn, $numeroPedido);
            $pedido['nombre_mesero'] = obtenerNombreMesero($conn, $pedido['mesero'] ?? 0);
            $pedido['comentarios'] = obtenerComentarios($conn, $numeroPedido);
        }
        
        return $pedido;
    } catch (Exception $e) {
        return null;
    }
}

function obtenerMesasLibres($conn) {
    try {
        $query = "
            SELECT numero_mesa 
            FROM mesas 
            WHERE id_pedido IS NULL OR id_pedido = ''
            ORDER BY numero_mesa
        ";
        
        $stmt = $conn->prepare($query);
        $stmt->execute();
        return $stmt->fetchAll(PDO::FETCH_ASSOC);
    } catch (Exception $e) {
        return [];
    }
}