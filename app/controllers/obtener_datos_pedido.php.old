<?php
/**
 * obtener_datos_pedido.php - CORREGIDO
 * Sin ORDER BY problemático
 */

// ✅ Desactivar TODOS los errores
error_reporting(0);
ini_set('display_errors', 0);
ini_set('display_startup_errors', 0);

// ✅ Header JSON primero
header('Content-Type: application/json; charset=utf-8');

// ✅ Output buffering
ob_start();

try {
    // ============================================
    // 1. VALIDAR PARÁMETRO
    // ============================================
    if (!isset($_GET['id_pedido'])) {
        throw new Exception('ID de pedido requerido');
    }
    
    $idPedido = (int)$_GET['id_pedido'];
    
    if ($idPedido <= 0) {
        throw new Exception('ID de pedido inválido');
    }
    
    // ============================================
    // 2. CONECTAR
    // ============================================
    $dbPath = __DIR__ . '/../../config/database.php';
    
    if (!file_exists($dbPath)) {
        throw new Exception('database.php no encontrado');
    }
    
    require_once $dbPath;
    
    $db = Database::getInstance();
    $conn = $db->getConnection();
    
    // ============================================
    // 3. OBTENER PRODUCTOS (query simple SIN ORDER BY)
    // ============================================
    $queryProductos = "
        SELECT 
            p.cantidad, 
            p.detalle,
            p.tipo_producto AS tipo_prod,
            pr.precio,
            prod.nombre AS nombre_producto
        FROM pedidos p
        LEFT JOIN precios pr ON p.id_pro = pr.idproduc AND p.tipo_producto = pr.tipo_prod
        LEFT JOIN productos prod ON p.id_pro = prod.id_pro
        WHERE p.numero_pedido = ?
    ";
    
    $stmt = $conn->prepare($queryProductos);
    $stmt->bindValue(1, $idPedido, PDO::PARAM_INT);
    $stmt->execute();
    $productos = $stmt->fetchAll(PDO::FETCH_ASSOC);
    
    // Convertir tipos
    foreach ($productos as &$producto) {
        $producto['cantidad'] = (int)($producto['cantidad'] ?? 0);
        $producto['precio'] = (float)($producto['precio'] ?? 0);
    }
    unset($producto);
    
    // ============================================
    // 4. COSTO DOMICILIO (opcional, puede fallar)
    // ============================================
    $costoDomicilio = null;
    try {
        $queryCosto = "SELECT precio FROM domicilios WHERE id_pedido = ? LIMIT 1";
        $stmt = $conn->prepare($queryCosto);
        $stmt->bindValue(1, $idPedido, PDO::PARAM_INT);
        $stmt->execute();
        $costo = $stmt->fetchColumn();
        if ($costo !== false) {
            $costoDomicilio = (float)$costo;
        }
    } catch (Exception $e) {
        // Si falla (tabla no existe), ignorar
    }
    
    // ============================================
    // 5. COMENTARIO (opcional, puede fallar)
    // ============================================
    $comentario = 'Sin comentarios';
    try {
        $queryComentario = "SELECT comentario FROM comentarios WHERE id_pedido = ? LIMIT 1";
        $stmt = $conn->prepare($queryComentario);
        $stmt->bindValue(1, $idPedido, PDO::PARAM_INT);
        $stmt->execute();
        $com = $stmt->fetchColumn();
        if ($com !== false && trim($com) !== '') {
            $comentario = trim($com);
        }
    } catch (Exception $e) {
        // Si falla (tabla no existe), ignorar
    }
    
    // ============================================
    // 6. RESPUESTA
    // ============================================
    ob_end_clean();
    
    echo json_encode([
        'success' => true,
        'productos' => $productos,
        'costo_domicilio' => $costoDomicilio,
        'comentario' => $comentario,
        'count' => count($productos)
    ], JSON_UNESCAPED_UNICODE);
    
} catch (PDOException $e) {
    ob_end_clean();
    error_log('Error BD obtener_datos_pedido: ' . $e->getMessage());
    
    echo json_encode([
        'success' => false,
        'message' => 'Error de base de datos',
        'error' => $e->getMessage(),
        'line' => $e->getLine(),
        'productos' => []
    ], JSON_UNESCAPED_UNICODE);
    
} catch (Exception $e) {
    ob_end_clean();
    error_log('Error obtener_datos_pedido: ' . $e->getMessage());
    
    echo json_encode([
        'success' => false,
        'message' => $e->getMessage(),
        'line' => $e->getLine(),
        'productos' => []
    ], JSON_UNESCAPED_UNICODE);
}

exit;