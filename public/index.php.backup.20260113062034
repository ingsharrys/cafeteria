    <?php if ($mostrarModal): ?>
    <!-- SCRIPT DEL MODAL -->
    <script>
    console.log('🔵 Modal debe mostrarse porque cajero está vacío');
    
    function inicializarModal() {
        if (typeof bootstrap === 'undefined') {
            console.error('❌ Bootstrap no disponible');
            setTimeout(inicializarModal, 100);
            return;
        }
        
        console.log('✅ Bootstrap disponible');
        
        const modalElement = document.getElementById('codigoModal');
        if (!modalElement) {
            console.error('❌ Modal no encontrado');
            return;
        }
        
        console.log('✅ Modal encontrado');
        
        const modal = new bootstrap.Modal(modalElement, {
            backdrop: 'static',
            keyboard: false
        });
        
        modal.show();
        console.log('✅ Modal mostrado');
        
        modalElement.addEventListener('shown.bs.modal', function () {
            document.getElementById('codigoInput').focus();
        });
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', inicializarModal);
    } else {
        inicializarModal();
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('codigoForm');
        if (!form) return;
        
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const codigo = document.getElementById('codigoInput').value.trim();
            const errorDiv = document.getElementById('errorMensaje');
            const successDiv = document.getElementById('successMensaje');
            const btnEnviar = document.getElementById('btnEnviar');
            const btnTexto = document.getElementById('btnTexto');
            const btnSpinner = document.getElementById('btnSpinner');
            
            if (!codigo) {
                errorDiv.textContent = 'Por favor, ingrese el código';
                errorDiv.style.display = 'block';
                successDiv.style.display = 'none';
                return;
            }
            
            btnEnviar.disabled = true;
            btnTexto.style.display = 'none';
            btnSpinner.style.display = 'inline-block';
            errorDiv.style.display = 'none';
            successDiv.style.display = 'none';
            
            console.log('🔵 Enviando código:', codigo);
            
            // ✅ USAR NUEVA RUTA DEL ROUTER
            fetch('<?php echo BASE_URL; ?>/api/meseros/validar', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'codigo=' + encodeURIComponent(codigo)
            })
            .then(response => {
                console.log('📥 Respuesta recibida:', response.status);
                return response.json();
            })
            .then(data => {
                console.log('📦 Datos:', data);
                
                if (data.status === 'success') {
                    console.log('✅ Código válido, recargando página...');
                    successDiv.innerHTML = '<i class="fas fa-check-circle"></i> ' + data.message;
                    successDiv.style.display = 'block';
                    errorDiv.style.display = 'none';
                    
                    setTimeout(function() {
                        console.log('🔄 Recargando...');
                        location.reload();
                    }, 1000);
                } else {
                    console.log('❌ Código incorrecto');
                    errorDiv.innerHTML = '<i class="fas fa-times-circle"></i> ' + data.message;
                    errorDiv.style.display = 'block';
                    successDiv.style.display = 'none';
                    
                    document.getElementById('codigoInput').value = '';
                    document.getElementById('codigoInput').focus();
                    
                    btnEnviar.disabled = false;
                    btnTexto.style.display = 'inline';
                    btnSpinner.style.display = 'none';
                }
            })
            .catch(error => {
                console.error('❌ Error:', error);
                errorDiv.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Error al procesar';
                errorDiv.style.display = 'block';
                
                btnEnviar.disabled = false;
                btnTexto.style.display = 'inline';
                btnSpinner.style.display = 'none';
            });
        });
        
        const input = document.getElementById('codigoInput');
        if (input) {
            input.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '');
            });
        }
    });
    </script>
    <?php endif; ?>

