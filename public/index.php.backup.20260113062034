    require_once __DIR__ . '/../bootstrap.php';
    
    // ============================================
    // 2. DETECTAR SI ES PETICIÓN A LA API
    // ============================================
    
    $requestUri = $_SERVER['REQUEST_URI'] ?? '';
    $isApiRequest = strpos($requestUri, '/api/') !== false 
                 || isset($_GET['api'])
                 || strpos($requestUri, '.php') !== false && strpos($requestUri, 'index.php') === false;
    
    if ($isApiRequest) {
        // ----------------------------------------
        // RUTA API: Usar Router
        // ----------------------------------------
        
        // Cargar router y rutas
        $router = require_once __DIR__ . '/../routes.php';
        
        // Ejecutar router
        $router->run();
        exit;
    }
    
    // ============================================
    // 3. RUTA NORMAL: Dashboard/Vistas
    // ============================================
    
    // Verificar autenticación
    if (!\Core\Session::get('user_id')) {
        \Core\Logger::security('Intento de acceso sin autenticación', [
            'ip' => $_SERVER['REMOTE_ADDR'] ?? 'unknown',
            'url' => $_SERVER['REQUEST_URI'] ?? 'unknown'
        ]);
        \Core\Response::redirectToLogin();
    }
    
    // Manejar logout
    if (isset($_GET['action']) && $_GET['action'] === 'logout') {
        $email = \Core\Session::get('user_email', 'unknown');
        \Core\Logger::logLogout($email);
        
        \Core\Session::destroy();
        \Core\Response::redirectWithSuccess(LOGIN_URL, 'Has cerrado sesión exitosamente.');
    }
    
    // ✅ VERIFICACIÓN DEL CAJERO
    $cajero = \Core\Session::get('cajero');
    $mostrarModal = empty($cajero);
    
    if ($mostrarModal) {
        error_log("DEBUG: Cajero vacío, mostrando modal");
    } else {
        error_log("DEBUG: Cajero encontrado: " . $cajero);
    }
    
    ?>
