# ==============================================================
#  Configuración de entorno — Sistema de Cafetería / PideYApp
# ==============================================================
# Copia este archivo a `.env` y rellena los valores reales.
# El archivo `.env` NUNCA debe subirse al repositorio (está en .gitignore).
# ==============================================================

# --- Aplicación ---
APP_ENV=production          # production | development
APP_DEBUG=false            # true solo en desarrollo
APP_URL=https://cafeteria.sharrys.com/

# --- Base de datos (MySQL) ---
DB_HOST=localhost
DB_NAME=nombre_de_tu_bd
DB_USER=usuario_de_tu_bd
DB_PASS=cambia_esta_password

# --- WhatsApp Cloud API (Meta) ---
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=
WA_PHONE_NUMBER_ID=
WA_WABA_ID=
WA_BUSINESS_NAME=
WA_MENU_BASE_URL=
WA_ADVISOR_PHONE=
WA_ADVISOR_URL=

# --- reCAPTCHA (opcional) ---
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# --- Sesión ---
SESSION_LIFETIME=14400
SESSION_DOMAIN=

# --- Correo (opcional) ---
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@pideyapp.com
MAIL_FROM_NAME=PideYAPP
